direction: right

frontend: Frontend {
  shape: rectangle
  style.fill: "#f0f4ff"
  style.stroke: "#4f6ef7"

  step1: Step 1\nFind Organizations
  step2: Step 2\nFind People
  step3: Step 3\nLeads & Campaign
  step4: Step 4\nResponse Monitor
}

backend: Local Backend\n(Node / Express) {
  shape: rectangle
  style.fill: "#f0fff4"
  style.stroke: "#38a169"

  storage: JSON Files\napollo_pending\nemail_queue\nresponses
}

n8n: n8n Automation {
  shape: rectangle
  style.fill: "#fffbeb"
  style.stroke: "#d97706"

  wf1: Org Search
  wf2: People Search
  wf3: Email Generation\n(Gemini via OpenRouter)
  wf4: Email Sending\n(Gmail)
}

pipedrive: Pipedrive\nCRM {
  shape: rectangle
  style.fill: "#fdf4ff"
  style.stroke: "#9333ea"
}

apollo: Apollo.io\nB2B Database {
  shape: rectangle
  style.fill: "#fff1f0"
  style.stroke: "#e53e3e"
}

# Frontend → Backend
frontend.step3 -> backend.storage: approve / decline emails
frontend.step4 -> backend.storage: read responses
frontend.step1 -> backend.storage: review pending orgs

# Frontend → n8n
frontend.step1 -> n8n.wf1: search orgs
frontend.step2 -> n8n.wf2: search people
frontend.step3 -> n8n.wf3: start campaign

# Frontend → Pipedrive
frontend.step1 -> pipedrive: read / write orgs
frontend.step2 -> pipedrive: read / write contacts
frontend.step3 -> pipedrive: read leads & labels

# n8n → External
n8n.wf1 -> apollo: enrich orgs
n8n.wf2 -> apollo: find people
n8n.wf3 -> n8n.wf4: generated email
n8n.wf1 -> pipedrive: create orgs
n8n.wf2 -> pipedrive: create contacts
n8n.wf3 -> pipedrive: update lead stage

# n8n → Backend (async callbacks)
n8n -> backend.storage: push emails, results, errors {
  style.stroke-dash: 4
}

# Backend → Frontend (polling)
backend -> frontend: polls every 3–10s {
  style.stroke-dash: 4
}
