# n8n Webhook URLs
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
N8N_WEBHOOK_URL_MANUAL_ORGANIZATION=https://aigeneers.app.n8n.cloud/webhook/organizations
N8N_WEBHOOK_URL_FILTERS_ORGANIZATION=https://aigeneers.app.n8n.cloud/webhook/organization-filters
VITE_N8N_APOLLO_ACCEPTED_URL=https://aigeneers.app.n8n.cloud/webhook/apollo-accepted

# Pipedrive API Key
VITE_PIPEDRIVE_API_KEY=your_pipedrive_api_key_here

# Cloudflare Tunnel Configuration
# Tunnel name (created with: cloudflared tunnel create sales-outreach-n8n)
CLOUDFLARE_TUNNEL_NAME=sales-outreach-n8n

# Your permanent tunnel URL (e.g., https://api.yourdomain.com or https://sales-outreach-n8n.yourdomain.com)
# This URL never changes and should be used in your n8n webhooks
CLOUDFLARE_TUNNEL_URL=https://...

# Server Port
PORT=3001