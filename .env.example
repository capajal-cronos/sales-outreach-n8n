# ─────────────────────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────────────────────
# Base URL of your n8n instance's webhook path. All 9 workflow
# endpoints (organizations, find-people, send-leads-mails,
# email-approval, ...) are derived from this single value.
# No trailing slash.
VITE_N8N_BASE_URL=https://your-n8n.app.n8n.cloud/webhook

# ─────────────────────────────────────────────────────────────
# Pipedrive
# ─────────────────────────────────────────────────────────────
VITE_PIPEDRIVE_API_KEY=your_pipedrive_api_key_here

# Pipedrive custom-field keys — run `npm run setup:pipedrive` to
# generate and auto-fill these.
VITE_PIPEDRIVE_PERSON_LINKEDIN_KEY=
VITE_PIPEDRIVE_PERSON_HEADLINE_KEY=
VITE_PIPEDRIVE_ORG_APOLLO_ID_KEY=

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel (only needed if n8n runs in the cloud and
# needs to reach your localhost — see N8N.md)
# ─────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_NAME=sales-outreach-n8n
CLOUDFLARE_TUNNEL_URL=https://api.yourdomain.com

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3001
