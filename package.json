{
  "name": "n8n-workflow-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_DEV_SESSION_ID=$(node -p Date.now()) vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "tunnel": "node start-cloudflare.js",
    "setup:pipedrive": "node scripts/setupPipedrive.js",
    "start": "concurrently -n vite,api,tunnel -c blue,green,magenta \"npm --silent run dev\" \"npm --silent run server\" \"npm --silent run tunnel\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^8.2.2",
    "vite": "^8.0.0"
  }
}
